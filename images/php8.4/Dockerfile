FROM php:8.4-apache-bullseye

ARG TZ=Europe/Brussels
ARG PUID=1000
ARG PGID=1000
ARG APACHE_RUN_USER=docker
ARG APACHE_RUN_GROUP=docker

ARG DOCKER_INSTALL_COMPOSER=yes
ARG DOCKER_INSTALL_IMAGE_OPTIMIZERS=yes
ARG DOCKER_INSTALL_LARAVEL=yes
ARG DOCKER_INSTALL_NODEJS=yes
ARG DOCKER_INSTALL_PHP_BCMATH=yes
ARG DOCKER_INSTALL_PHP_EXIF=yes
ARG DOCKER_INSTALL_PHP_GD=yes
ARG DOCKER_INSTALL_PHP_IMAGICK=yes
ARG DOCKER_INSTALL_PHP_INTL=yes
ARG DOCKER_INSTALL_PHP_MYSQLI=yes
ARG DOCKER_INSTALL_PHP_PDO_MYSQL=yes
ARG DOCKER_INSTALL_PHP_SOAP=yes
ARG DOCKER_INSTALL_PHP_SOCKETS=yes
ARG DOCKER_INSTALL_PHP_SODIUM=yes
ARG DOCKER_INSTALL_PYTHON3=yes
ARG DOCKER_INSTALL_SLATE=no
ARG DOCKER_INSTALL_WKHTMLTOPDF=yes
ARG DOCKER_INSTALL_PHP_PCNTL=yes
ARG DOCKER_INSTALL_SUPERVISOR=yes

ENV TZ=$TZ \
    PUID=$PUID \
    PGID=$PGID \
    APACHE_RUN_USER=$APACHE_RUN_USER \
    APACHE_RUN_GROUP=$APACHE_RUN_GROUP \
    DOCKER_INSTALL_COMPOSER=$DOCKER_INSTALL_COMPOSER \
    DOCKER_INSTALL_IMAGE_OPTIMIZERS=$DOCKER_INSTALL_IMAGE_OPTIMIZERS \
    DOCKER_INSTALL_LARAVEL=$DOCKER_INSTALL_LARAVEL \
    DOCKER_INSTALL_NODEJS=$DOCKER_INSTALL_NODEJS \
    DOCKER_INSTALL_PHP_BCMATH=$DOCKER_INSTALL_PHP_BCMATH \
    DOCKER_INSTALL_PHP_EXIF=$DOCKER_INSTALL_PHP_EXIF \
    DOCKER_INSTALL_PHP_GD=$DOCKER_INSTALL_PHP_GD \
    DOCKER_INSTALL_PHP_IMAGICK=$DOCKER_INSTALL_PHP_IMAGICK \
    DOCKER_INSTALL_PHP_INTL=$DOCKER_INSTALL_PHP_INTL \
    DOCKER_INSTALL_PHP_MYSQLI=$DOCKER_INSTALL_PHP_MYSQLI \
    DOCKER_INSTALL_PHP_PDO_MYSQL=$DOCKER_INSTALL_PHP_PDO_MYSQL \
    DOCKER_INSTALL_PHP_SOAP=$DOCKER_INSTALL_PHP_SOAP \
    DOCKER_INSTALL_PHP_SOCKETS=$DOCKER_INSTALL_PHP_SOCKETS \
    DOCKER_INSTALL_PHP_SODIUM=$DOCKER_INSTALL_PHP_SODIUM \
    DOCKER_INSTALL_PYTHON3=$DOCKER_INSTALL_PYTHON3 \
    DOCKER_INSTALL_SLATE=$DOCKER_INSTALL_SLATE \
    DOCKER_INSTALL_WKHTMLTOPDF=$DOCKER_INSTALL_WKHTMLTOPDF \
    DOCKER_INSTALL_PHP_PCNTL=$DOCKER_INSTALL_PHP_PCNTL \
    DOCKER_INSTALL_SUPERVISOR=$DOCKER_INSTALL_SUPERVISOR

COPY src/lap-installer.sh /tmp/lap-installer.sh
COPY src/bin/composer-use.sh /usr/local/bin/composer-use
COPY src/bin/node-use.sh /usr/local/bin/node-use
COPY src/bin/pre-start.sh /usr/local/bin/pre-start
COPY src/bin/start.sh /usr/local/bin/start

RUN set -eux; \
    chmod +x /tmp/lap-installer.sh \
    && /tmp/lap-installer.sh \
    && rm /tmp/lap-installer.sh
